# ── Chain ─────────────────────────────────────────────────────────────────────
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614

# Keeper wallet (must be funded with ETH to pay gas)
KEEPER_PRIVATE_KEY=0x...

# ── Contracts ─────────────────────────────────────────────────────────────────
COMMITMENT_REGISTRY_ADDRESS=0x...
COLLATERAL_VAULT_ADDRESS=0x...

# ── API ───────────────────────────────────────────────────────────────────────
API_PORT=3001
# Shared bearer token for /api/shares and /api/execute. Must match backend's KEEPER_API_SECRET.
API_SECRET=
API_BODY_LIMIT=256kb

# Optional: keeper → backend done-callback URL. Empty disables the callback.
BACKEND_URL=http://localhost:8080

# ── Execution ─────────────────────────────────────────────────────────────────
MAX_RETRIES=5
RETRY_BASE_DELAY_MS=2000

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./data/keeper.db

# ── ZK circuits ───────────────────────────────────────────────────────────────
CIRCUIT_JSON_PATH=../circuits/order_fill/target/order_fill.json
DCA_CIRCUIT_JSON_PATH=../circuits/dca/target/dca.json

# ── Threshold keeper────────────────────────────────────────────────
THRESHOLD_N=3
THRESHOLD_K=2
THRESHOLD_KEYS_FILE=./data/keeper-keys.json
