{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["hardhat.config.ts", "contracts/**/*", "test/**/*", "scripts/**/*"],
  "exclude": ["node_modules", "dist"]
}
