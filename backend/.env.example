# Server
PORT=8080

# PostgreSQL
DATABASE_URL=postgres://zstrategy:zstrategy@localhost:5432/zstrategy?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# Chain
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
CHAIN_ID=421614
COMMITMENT_REGISTRY_ADDRESS=0x...

# Chainlink ETH/USD feed on Arbitrum Sepolia
CHAINLINK_ETH_USD=0x...

# Keeper sidecar — backend triggers POST /api/execute when fill condition is met.
# KEEPER_API_SECRET must match the keeper's API_SECRET.
KEEPER_URL=http://localhost:3001
KEEPER_API_SECRET=

# Prometheus
METRICS_ENABLED=true
